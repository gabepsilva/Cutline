{
	"name": "cutline",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo '' ; husky || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"test:unit": "vitest",
		"test:unit:run": "vitest --run",
		"test:unit:coverage": "vitest --run --coverage",
		"test": "bun run test:unit:run && bun run test:e2e",
		"test:e2e": "playwright install && playwright test",
		"db:push": "drizzle-kit push",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:studio": "drizzle-kit studio",
		"jobs:worker": "bun scripts/jobs-worker.ts",
		"r2:config": "bash scripts/r2-bucket-config.sh",
		"auth:schema": "better-auth generate --config src/lib/server/auth.ts --output src/lib/server/db/auth.schema.ts --yes"
	},
	"overrides": {
		"drizzle-orm": "0.45.2",
		"lodash": "4.18.1",
		"@better-auth/core": "1.6.20"
	},
	"lint-staged": {
		"*.{js,ts,svelte,json,jsonc,css,html,md,yml,yaml}": "prettier --write"
	},
	"dependencies": {
		"@aws-sdk/client-s3": "^3.1075.0",
		"@aws-sdk/s3-request-presigner": "^3.1075.0",
		"@libsql/client": "^0.17.4",
		"better-auth": "~1.6.20",
		"drizzle-orm": "^0.45.2"
	},
	"devDependencies": {
		"@better-auth/cli": "^1.4.21",
		"@eslint/js": "^10.0.1",
		"@playwright/test": "^1.61.1",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/adapter-node": "^5.5.6",
		"@sveltejs/kit": "^2.67.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@types/node": "^24.13.2",
		"@vitest/browser-playwright": "^4.1.9",
		"@vitest/coverage-istanbul": "^4.1.9",
		"drizzle-kit": "^0.31.10",
		"eslint": "^10.5.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.19.0",
		"globals": "^17.7.0",
		"husky": "^9.1.7",
		"lint-staged": "^17.0.8",
		"playwright": "^1.61.1",
		"prettier": "^3.8.4",
		"prettier-plugin-svelte": "^4.1.1",
		"svelte": "^5.56.4",
		"svelte-check": "^4.7.1",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.62.0",
		"vite": "^8.1.0",
		"vitest": "^4.1.9",
		"vitest-browser-svelte": "^2.1.1",
		"wrangler": "^4.105.0"
	}
}
