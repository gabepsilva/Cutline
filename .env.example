# Jobs (ingest/transcription/export) run in a separate worker process, never the
# web server. Start it alongside `bun run dev` with: `bun run jobs:worker`.

# Logging — per-request access lines (method/path/status). Off by default; enable for debugging.
# LOG_ACCESS=true

# Drizzle
DATABASE_URL=file:local.db
# Turso remote only — omit for local file: URLs and CI.
# DATABASE_AUTH_TOKEN=

ORIGIN=""

# Better Auth
# For production use 32 characters and generated with high entropy
# https://www.better-auth.com/docs/installation
BETTER_AUTH_SECRET=""
# GitHub OAuth
# https://www.better-auth.com/docs/authentication/github
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# Cloudflare R2 (direct browser upload — M8-01)
# R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
# R2_BUCKET=cutline-prod
# R2_ACCESS_KEY_ID=""
# R2_SECRET_ACCESS_KEY=""

# AssemblyAI (speech-to-text — M9-01)
# Required for transcription jobs; without it they fail with "ASSEMBLYAI_API_KEY is not configured".
# ASSEMBLYAI_API_KEY=""
