# Jobs — set to "false" in production; use `bun run jobs:worker` instead.
# INLINE_JOB_WORKER=false

# Docker Compose dev (#202) — compose.yaml overrides DATABASE_URL and sets INLINE_JOB_WORKER=false.
# Copy this file to .env, then: make dev-up  →  http://localhost:5173
# DOCKER_DEV=1 is set on the app service for Vite bind-mount polling/HMR.
# Optional: WORKER_ID=compose-worker (default in compose for the worker service).
# External keys (R2, AssemblyAI, GitHub OAuth) stay in .env; UI works without them.

# Logging — per-request access lines (method/path/status). Off by default; enable for debugging.
# LOG_ACCESS=true

# Drizzle
DATABASE_URL=file:local.db
# Turso remote only — omit for local file: URLs and CI.
# DATABASE_AUTH_TOKEN=

ORIGIN=""

# Better Auth
# For production use 32 characters and generated with high entropy
# https://www.better-auth.com/docs/installation
BETTER_AUTH_SECRET=""
# GitHub OAuth
# https://www.better-auth.com/docs/authentication/github
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# Cloudflare R2 (direct browser upload — M8-01)
# R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
# R2_BUCKET=cutline-prod
# R2_ACCESS_KEY_ID=""
# R2_SECRET_ACCESS_KEY=""
# Public staging bucket for AssemblyAI transcription (#194) — values in Cutline-PROD (1Password).
# R2_PUBLIC_BUCKET=""
# R2_PUBLIC_BASE_URL=""

# AssemblyAI (speech-to-text — M9-01)
# Required for transcription jobs; without it they fail with "ASSEMBLYAI_API_KEY is not configured".
# ASSEMBLYAI_API_KEY=""
